<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#2C974B" />
            <corners android:radius="6dp" />
            <stroke android:width="1dp" android:color="#2c974b" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#2DA44E" />
            <corners android:radius="6dp" />
            <stroke android:width="1dp" android:color="#2da44e" />
        </shape>
    </item>
</selector>
