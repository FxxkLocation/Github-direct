<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GitHub Direct"
                android:textSize="26sp"
                android:textColor="#24292F"
                android:textStyle="bold" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
            <ImageView android:id="@+id/logo" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_github" />
        </LinearLayout>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="模块状态"
                android:textSize="14sp"
                android:textColor="#57606A"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/status_indicator"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/shape_circle_gray" />
                <TextView
                    android:id="@+id/status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#24292F"
                    tools:text="等待框架连接..." />
            </LinearLayout>

            <TextView
                android:id="@+id/framework_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#57606A"
                android:layout_marginTop="8dp"
                tools:text="Framework info" />
        </LinearLayout>

        <!-- Control Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="代理控制"
                android:textSize="14sp"
                android:textColor="#57606A"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/vpn_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#24292F"
                android:layout_marginBottom="16dp"
                android:lineSpacingExtra="2dp"
                tools:text="DNS 代理已停止。" />

            <Button
                android:id="@+id/btn_vpn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="开启代理"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Tools Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="连通性测试"
                android:textSize="14sp"
                android:textColor="#57606A"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_test"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/btn_secondary"
                    android:text="测试 DNS"
                    android:textColor="#24292F"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_refresh"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/btn_secondary"
                    android:text="测试连通性"
                    android:textColor="#24292F"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- Output Terminal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_console"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="输出日志"
                    android:textSize="12sp"
                    android:textColor="#57606A"
                    android:textStyle="bold" />

                <ProgressBar android:indeterminateTint="#57606A"
                    android:id="@+id/progress_spinner"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:indeterminate="true"
                    android:visibility="invisible" />
            </LinearLayout>

            <TextView
                android:id="@+id/dns_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#24292F"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp"
                android:text="等待测试..." />
        </LinearLayout>

        <!-- Extra Actions Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_tg"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/btn_secondary"
                android:text="加入 Telegram 群组"
                android:textColor="#24292F"
                android:textSize="12sp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_star"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/btn_secondary"
                android:text="给项目一个 Star"
                android:textColor="#24292F"
                android:textSize="12sp"
                android:textAllCaps="false" />
        </LinearLayout>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="基于 Xposed 框架本地运行\nCreated by Mai_xiyu"
            android:textSize="12sp"
            android:textColor="#8C959F"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>

